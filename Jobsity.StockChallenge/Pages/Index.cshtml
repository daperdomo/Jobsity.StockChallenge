@page
@model IndexModel
@{
    ViewData["Title"] = "Chat";
    var rooms = Jobsity.StockChallenge.Application.Common.ChatRooms.All;
}

<section class="chat-shell">
    <header class="chat-header">
        <div>
            <p class="chat-eyebrow">Chat rooms</p>
            <h1>Stock Challenge Chat</h1>
        </div>
        <p class="chat-user">@User.Identity?.Name</p>
    </header>

    <nav class="chat-room-tabs" aria-label="Chat rooms">
        @foreach (var room in rooms)
        {
            <button class="chat-room-tab @(room == rooms[0] ? "active" : string.Empty)" type="button" data-room="@room">
                @room
            </button>
        }
    </nav>

    <div id="messagesList" class="chat-messages" aria-live="polite"></div>

    <form id="messageForm" class="chat-composer">
        <input id="messageInput" class="form-control" maxlength="1000" autocomplete="off" placeholder="Write a message or /stock=aapl.us" />
        <button class="btn btn-primary" type="submit">Send</button>
    </form>
</section>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@10.0.0/dist/browser/signalr.min.js"></script>
    <script src="~/js/chat.js" asp-append-version="true"></script>
}
